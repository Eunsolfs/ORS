DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# SQLite (dev default)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# MySQL (baota)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=ors
# DB_USER=ors
# DB_PASSWORD=strong-password
# DB_HOST=127.0.0.1
# DB_PORT=3306

# Production example
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=ors.example.com,127.0.0.1,localhost
# DJANGO_CSRF_TRUSTED_ORIGINS=https://ors.example.com

DJANGO_CSRF_TRUSTED_ORIGINS=

# 登录会话有效期（秒）
# 无操作超过该时长将过期；默认 12 小时
DJANGO_SESSION_IDLE_AGE=43200
# 登录后最长有效期（秒），即使持续操作也会在此时长后强制重新登录；默认 12 小时
DJANGO_SESSION_ABSOLUTE_AGE=43200
# 登录验证码模式：digit(纯数字) / alpha(纯字母) / alnum(数字字母混合)
ORS_LOGIN_CAPTCHA_MODE=alnum
# 登录验证码长度：建议 4-8，默认 5
ORS_LOGIN_CAPTCHA_LENGTH=5

# 可选：交班表导出 PDF 所需 LibreOffice（soffice）。未设置时自动探测 PATH/常见安装路径。
# ORS_SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
