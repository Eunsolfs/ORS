# 复制为同目录下的 .env 后再启动 Compose（不要提交 .env）
# cp env.example .env

# —— Django ——
DJANGO_SECRET_KEY=请替换为足够长的随机字符串
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=你的域名,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://你的域名
# 反代 HTTPS 时建议保持默认 True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=True

# —— MySQL（与 compose 中 db 服务一致；DB_HOST 由 compose 固定为 db，勿改）——
DB_ENGINE=django.db.backends.mysql
DB_NAME=ors
DB_USER=ors
DB_PASSWORD=请设置强密码
DB_PORT=3306

# MySQL 容器 root 密码（仅 db 服务使用）
MYSQL_ROOT_PASSWORD=请另设一个强密码

# —— 首次初始化账号（可省略密码，容器会在日志里生成随机串，建议仍写入固定值）——
ROOT_USERNAME=root
ROOT_PASSWORD=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
DEPT_NAME=手术室
DEPT_CODE=ors
ADMIN_NAME=科室管理员

# —— Gunicorn（容器内监听固定 8000，与 compose 中端口映射右侧一致）——
GUNICORN_WORKERS=3

# 映射到宿主机的端口（修改后需与 1Panel 反代目标一致）
APP_PUBLISH_PORT=8000

# 可选：交班表导出 PDF（soffice）。默认镜像内未装 LibreOffice，留空即可；需 PDF 时再扩展镜像或挂路径。
# ORS_SOFFICE_PATH=
